# 1. Ignore everything by default
*

# 2. Allow directories to be scanned (crucial for git to traverse subfolders)
!**/

# 3. Whitelist source code and build configuration files
!*.cpp
!*.h
!*.hpp
!*.c
!*.txt
!*.md
!CMakeLists.txt

# 4. Whitelist configuration and settings files
!.gitignore
!.vscode/
!.vscode/**

# 5. Specifically ignore IDE settings, build directories, and cache
.idea/
cmake-build-*/
build/
bin/
out/
obj/

# windows executables
*.exe


